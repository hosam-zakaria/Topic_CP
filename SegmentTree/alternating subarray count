#include <bits/stdc++.h>
#define ll long long
#define ld long double
#define Hosam ios::sync_with_stdio(0); cin.tie(0);
using namespace std;

const ll oo = 1e9, N = 1e6, MOD = 1e9 + 7;
const ld PI = acos(-1.0L), EPS = 1e-9;



struct Node{
    ll prefx, sufx, ans, len; 
    Node(){ prefx = sufx = ans = 0; len = 1; }
    Node(ll val){ prefx = sufx = ans = val; len = 1; }
    Node(ll val, ll len){ prefx = sufx = ans = val; this->len = len; }
}; 
struct segtree {
    vector<Node> tree; 
    segtree(ll n){
        tree.resize(n << 2); 
    }
    segtree(ll n, vector<ll> &v){
        tree.resize(n << 2); 
        build(1, 0, n - 1, v); 
    }

    Node merge(Node left, Node right){
        Node ret; 
        ret.prefx = (left.prefx == left.len ? left.len + right.prefx : left.prefx);
        ret.sufx = (right.sufx == right.len ? right.len + left.sufx : right.sufx);
        ret.len = left.len + right.len; 
        ret.ans = left.ans + right.ans + (left.sufx * right.prefx); 
        return ret; 
    }

    void build(ll node , ll l, ll r, vector<ll> &v){
        if(l == r){
            tree[node] = Node(v[l]); 
            return; 
        }

        ll mid = l + (r - l) / 2; 
        build(node << 1, l, mid, v); 
        build(node << 1 | 1, mid + 1, r, v); 
        tree[node] = merge(tree[node << 1] , tree[node << 1 | 1]); 
    }   

    void update(ll node, ll l, ll r, ll idx, ll val){
        if(l == r){
            tree[node] = Node(val); 
            return; 
        }

        ll mid = l + (r - l) / 2; 
        if(idx <= mid){
            update(node << 1, l, mid , idx, val);
        }else{
            update(node << 1 | 1, mid + 1, r , idx, val);
        }
        tree[node] = merge(tree[2 * node], tree[2 * node + 1]);
    }

    Node query(ll node, ll l, ll r, ll s, ll e){
        if(l > e || r < s){
            return Node(0, 0); 
        }
        if(l >= s && r <= e){
            return tree[node]; 
        }

        ll mid = l + (r - l) / 2; 
        return merge(query(node << 1, l, mid, s, e) , query(node << 1 | 1, mid + 1, r, s, e)); 
    }
};

void solve(){
    ll n, m; 
    cin >> n >> m; 
    vector<ll> v(n - 1); 
    ll prev; 
    cin >> prev; 
    
    for(ll i = 1; i < n ;i++){
        ll cur; 
        cin >> cur; 

        v[i - 1] = (cur ^ prev); 

        prev = cur; 
    }

    
    ll ty, l, r; 
    segtree seg(n - 1, v); 
    while(m--){
        cin >> ty >> l >> r; 
        l--; r--; 
        if(ty == 1){
            if(l > 0) {
                v[l - 1] ^= 1; 
                seg.update(1, 0, n - 2, l - 1, v[l - 1]);
            }
            if(r < n - 1){
                v[r] ^= 1; 
                seg.update(1, 0, n - 2, r, v[r]);
            }
        }else {
            if(l == r){ 
                cout << 1 << endl; 
            }else {
                Node res = seg.query(1, 0, n - 2, l, r - 1);
                cout << (r - l + 1) + res.ans << endl;
            }
        }
    }
}

int main(){
    Hosam;
    solve();
    return 0;
}
